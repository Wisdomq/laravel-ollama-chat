    }
  },
  "6": {
    "inputs": {
      "frame_rate": 25,
      "loop_count": 0,
      "filename_prefix": "ReActor_FaceSwap_Video",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 19,
      "save_metadata": true,
      "trim_to_audio": false,
      "pingpong": false,
      "save_output": true,
      "images": [
        "4",
        0
